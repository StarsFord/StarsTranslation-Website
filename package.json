{
  "name": "stars-translation-blogger",
  "version": "1.0.0",
  "description": "StarsTranslations - Translation blog platform",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "tsx watch server/index.ts",
    "server:js": "nodemon server/index.js",
    "client": "vite",
    "build": "tsc && vite build",
    "build:backend": "tsc",
    "build:frontend": "vite build",
    "preview": "vite preview",
    "setup-db": "tsx server/setup-db.ts",
    "create-admin": "tsx scripts/create-admin.ts",
    "promote-user": "tsx scripts/promote-user.ts",
    "health-check": "tsx scripts/health-check.ts",
    "update-user": "tsx scripts/update-user-data.ts",
    "add_ext-collumn": "tsx scripts/add-external-links-column.ts"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.18.0",
    "axios": "^1.6.5",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.7.0",
    "passport-patreon": "^1.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.1",
    "sql.js": "^1.10.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.10.1",
    "@types/passport": "^1.0.17",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^5.0.11"
  }
}
