# Server Configuration
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# Patreon OAuth
PATREON_CLIENT_ID=your-patreon-client-id
PATREON_CLIENT_SECRET=your-patreon-client-secret
PATREON_CALLBACK_URL=http://localhost:3000/auth/patreon/callback

# Database
DATABASE_PATH=./database.db

# File Uploads
MAX_FILE_SIZE=5368709120

# Google Cloud Storage
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=starstranslations-uploads
GCS_BUCKET_LOCATION=US
# For local development, use service account key file:
# GCP_KEY_FILE=./path/to/service-account-key.json
# For production (Cloud Run), leave empty - will use default credentials
